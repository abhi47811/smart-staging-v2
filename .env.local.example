# =============================================================================
# Smart Staging — Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (REQUIRED)
# Get these from: https://supabase.com/dashboard > Project Settings > API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# App URL (REQUIRED for OAuth redirect + post-generation triggers)
# Development: http://localhost:3000
# Production:  your Vercel URL e.g. https://smart-staging.vercel.app
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# AI Models — Generation Pipeline (optional: mock mode used when absent)
# -----------------------------------------------------------------------------

# Replicate API — Flux Pro, IC-Light, RealESRGAN, SAM2, CLIP
# https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_token_here

# OpenAI — design brief generation (GPT-4o) + render suggestions
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here

# Anthropic — alternative LLM for brief generation + suggestions (Claude)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# NOTE: At least one LLM key needed for AI features.
# Without any keys the system falls back to rule-based mock generation.

# Anthropic Claude is preferred — Claude Sonnet is the model used for
# design briefs (M06) and AI suggestions (M18). OpenAI is the fallback.

# -----------------------------------------------------------------------------
# Houspire Staging API (optional — alternative generation backend)
# URL: https://houspire-ai-staging-beta-v2-17146429325.us-west1.run.app
# When set, this can be used as an alternative to the Replicate pipeline
# for virtual staging, furniture placement, and room transformations.
# -----------------------------------------------------------------------------
HOUSPIRE_STAGING_API_KEY=AIzaSyAUNnWX3tBBy5poXbckSSNH8m68Su5WL4w

# -----------------------------------------------------------------------------
# Mock Mode
# The app runs in mock mode when REPLICATE_API_TOKEN is absent or empty.
# In mock mode: the original uploaded image passes through all pipeline stages.
# All DB writes, scene analysis, and brief generation still fire normally.
# Perfect for UI development and testing without burning API credits.
# -----------------------------------------------------------------------------
# MOCK_MODE=true  # (auto-detected — just leave REPLICATE_API_TOKEN blank)
